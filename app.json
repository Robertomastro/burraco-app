{
  "expo": {
    "name": "Controlla Punti",
    "slug": "burraco-app",
    "version": "1.0.0",
    "sdkVersion": "52.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#1a9e9e",
      "image": "./assets/icon.png",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Serve per fotografare il segnapunti del Burraco.",
        "NSPhotoLibraryUsageDescription": "Serve per caricare la foto del segnapunti.",
        "NSPhotoLibraryAddUsageDescription": "Serve per salvare le foto del segnapunti nell'album Burraco."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a9e9e"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ],
      "package": "com.robertomastro.burracoapp"
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Consenti l'accesso alle foto per salvare i segnapunti.",
          "savePhotosPermission": "Consenti il salvataggio delle foto nell'album Burraco.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e8d40e18-d0e6-4989-b85c-f09963cd0b9f"
      }
    }
  }
}
